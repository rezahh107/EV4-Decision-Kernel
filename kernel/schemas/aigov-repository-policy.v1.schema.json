{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/aigov-repository-policy.v1.schema.json",
  "title": "EV4 AIGOV Repository Policy v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["policy_id", "policy_version", "standard", "repository", "plan", "authority", "capability_lifecycle", "change_classes", "security_profile", "scope_contract", "evidence_contract", "reporting_contract", "sequence", "rules", "roadmap_preservation"],
  "properties": {
    "policy_id": {"const": "aigov-repository-policy.v1"},
    "policy_version": {"const": "1.0.0"},
    "standard": {"type": "object", "additionalProperties": false, "required": ["standard_id", "standard_version", "manifest_path", "raw_source_sha256"], "properties": {"standard_id": {"const": "AI_AUTHORITY_DETERMINISTIC_GOVERNANCE_SSOT"}, "standard_version": {"const": "1.1.0"}, "manifest_path": {"type": "string", "minLength": 1}, "raw_source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}},
    "repository": {"type": "object", "additionalProperties": false, "required": ["repository", "default_branch", "visibility", "status_authority", "durable_roadmap_authority"], "properties": {"repository": {"const": "rezahh107/EV4-Decision-Kernel"}, "default_branch": {"const": "main"}, "visibility": {"enum": ["public", "private"]}, "status_authority": {"const": "planning/NEXT_WORK.md"}, "durable_roadmap_authority": {"const": "planning/KERNEL_EXECUTION_PLAN.md"}}},
    "plan": {"type": "object", "additionalProperties": false, "required": ["plan_id", "plan_version", "audit_base_sha", "active_batch", "change_class"], "properties": {"plan_id": {"const": "GOV-ADOPTION-EV4-DECISION-KERNEL-5FF5D7B-V2"}, "plan_version": {"const": 2}, "audit_base_sha": {"const": "5ff5d7b20db11af36ab787eb8ac2d1127ea74644"}, "active_batch": {"const": "BATCH_A"}, "change_class": {"const": "L3"}}},
    "authority": {"type": "object", "additionalProperties": false, "required": ["merge_authority", "repository_owner", "auto_merge", "independent_exact_head_review", "human_technical_approval", "implementation_agent_may_self_review", "post_merge_verification"], "properties": {"merge_authority": {"const": "owner_only"}, "repository_owner": {"const": "rezahh107"}, "auto_merge": {"const": "forbidden"}, "independent_exact_head_review": {"const": "required"}, "human_technical_approval": {"const": "not_evidence"}, "implementation_agent_may_self_review": {"const": false}, "post_merge_verification": {"const": "required_per_batch"}}},
    "capability_lifecycle": {"type": "object", "required": ["states", "current_state", "completion_requires_default_branch_receipt", "registration_is_not_activation", "merge_is_not_completion"], "additionalProperties": false, "properties": {"states": {"type": "array", "minItems": 9, "uniqueItems": true, "items": {"type": "string"}}, "current_state": {"enum": ["active_implementation", "pending_exact_head_validation", "pending_independent_review", "pending_owner_merge", "pending_exact_main_verification", "completed", "blocked"]}, "completion_requires_default_branch_receipt": {"const": true}, "registration_is_not_activation": {"const": true}, "merge_is_not_completion": {"const": true}}},
    "change_classes": {"type": "array", "minItems": 5, "maxItems": 5, "items": {"type": "object", "additionalProperties": false, "required": ["id", "meaning", "minimum_verification_budget", "minimum_reporting_budget"], "properties": {"id": {"enum": ["L0", "L1", "L2", "L3", "L4"]}, "meaning": {"type": "string", "minLength": 1}, "minimum_verification_budget": {"type": "integer", "minimum": 1}, "minimum_reporting_budget": {"type": "integer", "minimum": 1}}}},
    "security_profile": {"type": "object", "additionalProperties": false, "required": ["profile_id", "fail_closed_on_missing_evidence", "treat_repository_inputs_as_untrusted", "immutable_action_pins_required", "workflow_permissions_must_not_expand", "secrets_must_not_change", "forbidden_changes"], "properties": {"profile_id": {"const": "standard_minimum_public_repository"}, "fail_closed_on_missing_evidence": {"const": true}, "treat_repository_inputs_as_untrusted": {"const": true}, "immutable_action_pins_required": {"const": true}, "workflow_permissions_must_not_expand": {"const": true}, "secrets_must_not_change": {"const": true}, "forbidden_changes": {"type": "array", "minItems": 10, "uniqueItems": true, "items": {"type": "string"}}}},
    "scope_contract": {"type": "object", "required": ["required_sets", "scope_revision_algorithm", "head_binding", "silent_material_deletion"], "additionalProperties": false, "properties": {"required_sets": {"type": "array", "minItems": 5, "uniqueItems": true, "items": {"type": "string"}}, "scope_revision_algorithm": {"const": "sha256-jcs-without-scope_revision"}, "head_binding": {"const": "exact_runtime_head"}, "silent_material_deletion": {"const": "forbidden"}}},
    "evidence_contract": {"type": "object", "additionalProperties": false, "required": ["manifest_required", "stable_inputs_and_outputs_required", "exact_head_required", "completion_receipt_default_branch_required", "target_authored_claim_is_not_external_authority"], "properties": {"manifest_required": {"const": true}, "stable_inputs_and_outputs_required": {"const": true}, "exact_head_required": {"const": true}, "completion_receipt_default_branch_required": {"const": true}, "target_authored_claim_is_not_external_authority": {"const": true}}},
    "reporting_contract": {"type": "object", "additionalProperties": false, "required": ["material_failures_must_be_reported", "known_limitations_must_be_reported", "prompt_or_coaching_text_is_not_completion_evidence"], "properties": {"material_failures_must_be_reported": {"const": true}, "known_limitations_must_be_reported": {"const": true}, "prompt_or_coaching_text_is_not_completion_evidence": {"const": true}}},
    "sequence": {"type": "object", "additionalProperties": false, "required": ["ordered_events", "review_invalidated_by_head_change", "review_invalidated_by_scope_revision_change", "owner_merge_cannot_be_skipped"], "properties": {"ordered_events": {"type": "array", "minItems": 8, "uniqueItems": true, "items": {"type": "string"}}, "review_invalidated_by_head_change": {"const": true}, "review_invalidated_by_scope_revision_change": {"const": true}, "owner_merge_cannot_be_skipped": {"const": true}}},
    "rules": {"type": "array", "minItems": 14, "maxItems": 14, "items": {"type": "object", "additionalProperties": false, "required": ["rule_id", "risk", "session_scope", "enforcement"], "properties": {"rule_id": {"pattern": "^AIGOV-[A-Z-]+-001$", "type": "string"}, "risk": {"enum": ["Critical", "High"]}, "session_scope": {"enum": ["per_session", "per_artifact", "per_increment", "cross_turn"]}, "enforcement": {"type": "string", "minLength": 1}}}},
    "roadmap_preservation": {"type": "object", "additionalProperties": false, "required": ["original_kroad_ids", "kroad_012r_status", "coverage_status", "coverage_promotion_effect"], "properties": {"original_kroad_ids": {"type": "array", "minItems": 7, "maxItems": 7, "uniqueItems": true, "items": {"pattern": "^KROAD-01[2-8]$", "type": "string"}}, "kroad_012r_status": {"const": "historical_non_authoritative"}, "coverage_status": {"const": "not_measurable_pending_external_promotion"}, "coverage_promotion_effect": {"const": "none"}}}
  }
}
