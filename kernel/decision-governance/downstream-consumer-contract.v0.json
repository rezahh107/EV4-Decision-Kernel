      "resolver_rule_ref",
      "decision_record_ref",
      "l2_audit_result_ref",
      "vertical_slice_ref"
    ],
    "missing_ref_set_must_equal_null_decision_ref_fields": true,
    "evidence_gap_source_type_required": true
  },
  "unsupported_family_policy": {
    "outcome": "insufficient_evidence",
    "resolver_backed_claim_allowed": false,
    "free_decision_allowed": false,
    "requires_missing_kernel_refs": true
  },
  "missing_reference_policy": {
    "kernel_consumed_with_missing_refs_allowed": false,
    "outcome": "fail_closed",
    "diagnostic_code": "DOWNSTREAM_CONSUMER_REQUIRED_KERNEL_REF_MISSING"
