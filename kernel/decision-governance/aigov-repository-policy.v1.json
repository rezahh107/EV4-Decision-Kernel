    {"rule_id": "AIGOV-MERGE-001", "risk": "Critical", "session_scope": "cross_turn", "enforcement": "owner_sequence_and_exact_main"},
    {"rule_id": "AIGOV-CHANGE-CLASS-001", "risk": "Critical", "session_scope": "per_increment", "enforcement": "deterministic_classifier"},
    {"rule_id": "AIGOV-EVIDENCE-PROPORTIONALITY-001", "risk": "High", "session_scope": "per_increment", "enforcement": "verification_budget_validator"},
    {"rule_id": "AIGOV-REPORTING-001", "risk": "High", "session_scope": "per_increment", "enforcement": "reporting_budget_validator"},
    {"rule_id": "AIGOV-SECURITY-PROFILE-001", "risk": "High", "session_scope": "per_increment", "enforcement": "security_profile_validator"},
    {"rule_id": "AIGOV-HUMAN-001", "risk": "High", "session_scope": "cross_turn", "enforcement": "evidence_type_validator"},
