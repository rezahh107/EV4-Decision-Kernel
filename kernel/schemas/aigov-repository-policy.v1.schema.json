{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/aigov-repository-policy.v1.schema.json",
  "title": "EV4 AIGOV Repository Policy v1.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policy_id",
    "policy_version",
    "standard",
    "repository",
    "plan",
    "authority",
    "capability_lifecycle",
    "change_classes",
    "security_profile",
    "scope_contract",
    "evidence_contract",
    "reporting_contract",
    "sequence",
    "rules",
    "roadmap_preservation"
  ],
  "properties": {
    "policy_id": {"const": "aigov-repository-policy.v1"},
    "policy_version": {"const": "1.1.0"},
    "standard": {"type": "object"},
    "repository": {"type": "object"},
    "plan": {
      "type": "object",
      "required": ["plan_id", "plan_version", "audit_base_sha", "active_batch", "change_class"],
      "properties": {
        "plan_id": {"const": "GOV-ADOPTION-EV4-DECISION-KERNEL-86E25A9-V4"},
        "plan_version": {"const": 4},
        "audit_base_sha": {"pattern": "^[0-9a-f]{40}$"},
        "active_batch": {"const": "BATCH_B"},
        "change_class": {"const": "L3"}
      }
    },
    "authority": {
      "type": "object",
      "required": ["merge_authority", "repository_owner", "auto_merge", "independent_exact_head_review", "independent_review_required", "missing_independent_review_is_blocking", "stale_independent_review_is_blocking", "review_sequence_is_blocking", "review_provenance_is_blocking", "human_technical_approval", "implementation_agent_may_self_review", "post_merge_verification"],
      "properties": {
        "merge_authority": {"const": "owner_only"},
        "repository_owner": {"const": "rezahh107"},
        "auto_merge": {"const": "forbidden"},
        "independent_exact_head_review": {"const": "optional_advisory"},
        "independent_review_required": {"const": false},
        "missing_independent_review_is_blocking": {"const": false},
        "stale_independent_review_is_blocking": {"const": false},
        "review_sequence_is_blocking": {"const": false},
        "review_provenance_is_blocking": {"const": false},
        "human_technical_approval": {"const": "not_evidence"},
        "implementation_agent_may_self_review": {"const": false},
        "post_merge_verification": {"const": "required_per_batch"}
      }
    },
    "capability_lifecycle": {"type": "object"},
    "change_classes": {"type": "array", "minItems": 5, "maxItems": 5},
    "security_profile": {"type": "object"},
    "scope_contract": {"type": "object"},
    "evidence_contract": {"type": "object"},
    "reporting_contract": {"type": "object"},
    "sequence": {
      "type": "object",
      "required": ["ordered_events", "advisory_review_event", "owner_merge_cannot_be_skipped"],
      "properties": {
        "ordered_events": {"const": ["start_preflight", "scope_committed", "scope_disclosed", "implementation_complete", "exact_head_validated", "owner_merge", "exact_main_verified"]},
        "advisory_review_event": {"const": "optional_non_blocking"},
        "owner_merge_cannot_be_skipped": {"const": true}
      }
    },
    "rules": {"type": "array", "minItems": 14, "maxItems": 14},
    "roadmap_preservation": {"type": "object"}
  }
}
