{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/aigov-scope-manifest.v1.schema.json",
  "title": "EV4 AIGOV Scope Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "scope_id", "plan_id", "batch_id", "repository", "base_branch", "base_sha", "head_binding", "change_class", "scope_revision", "committed", "excluded", "deferred_not_deleted", "dependencies", "completion_evidence", "authorized_operations", "forbidden_changes"],
  "properties": {
    "schema_version": {"const": "aigov-scope-manifest.v1"},
    "scope_id": {"type": "string", "pattern": "^aigov-scope\\.[a-z0-9._-]+$"},
    "plan_id": {"const": "GOV-ADOPTION-EV4-DECISION-KERNEL-5FF5D7B-V2"},
    "batch_id": {"enum": ["BATCH_A", "BATCH_B"]},
    "repository": {"const": "rezahh107/EV4-Decision-Kernel"},
    "base_branch": {"const": "main"},
    "base_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "head_binding": {"const": "derived_at_runtime"},
    "change_class": {"enum": ["L0", "L1", "L2", "L3", "L4"]},
    "scope_revision": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "committed": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "excluded": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "deferred_not_deleted": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "dependencies": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "completion_evidence": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "authorized_operations": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "forbidden_changes": {"type": "array", "minItems": 10, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
  }
}
