{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/aigov-review-receipt.v1.schema.json",
  "title": "EV4 AIGOV Independent Review Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "receipt_id", "plan_id", "batch_id", "repository", "head_sha", "scope_revision", "reviewer", "implementer", "protocol_version", "verdict", "reviewed_at", "findings"],
  "properties": {
    "schema_version": {"const": "aigov-review-receipt.v1"},
    "receipt_id": {"type": "string", "minLength": 1},
    "plan_id": {"const": "GOV-ADOPTION-EV4-DECISION-KERNEL-5FF5D7B-V2"},
    "batch_id": {"enum": ["BATCH_A", "BATCH_B"]},
    "repository": {"const": "rezahh107/EV4-Decision-Kernel"},
    "head_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "scope_revision": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "reviewer": {"type": "object", "additionalProperties": false, "required": ["identity", "provider", "independent"], "properties": {"identity": {"type": "string", "minLength": 1}, "provider": {"type": "string", "minLength": 1}, "independent": {"const": true}}},
    "implementer": {"type": "object", "additionalProperties": false, "required": ["identity", "provider"], "properties": {"identity": {"type": "string", "minLength": 1}, "provider": {"type": "string", "minLength": 1}}},
    "protocol_version": {"const": "AIGOV-REVIEW-COMPATIBILITY-1.0.0"},
    "verdict": {"enum": ["GREEN_MERGE_RECOMMENDED", "YELLOW_REPAIR_OR_VERIFICATION_REQUIRED", "RED_DO_NOT_MERGE", "BLOCKED_INSUFFICIENT_EVIDENCE"]},
    "reviewed_at": {"type": "string", "format": "date-time"},
    "findings": {"type": "array", "items": {"type": "object", "required": ["severity", "summary"], "additionalProperties": false, "properties": {"severity": {"enum": ["critical", "high", "medium", "low", "info"]}, "summary": {"type": "string", "minLength": 1}}}}
  }
}
