{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/coverage-runtime-proof-receipt.v1.schema.json",
  "title": "EV4 Coverage Runtime Proof Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["receipt_id", "receipt_version", "receipt_type", "subject", "provenance", "runtime_scope", "observations", "source_lineage", "limitations", "claims"],
  "properties": {
    "receipt_id": { "type": "string", "pattern": "^runtime-proof\\.[a-z0-9._-]+$" },
    "receipt_version": { "const": "1.0.0" },
    "receipt_type": { "const": "runtime_proof" },
    "subject": { "$ref": "#/$defs/subject" },
    "provenance": { "$ref": "#/$defs/provenance" },
    "runtime_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["environment_id", "observation_kind", "captured_at", "result"],
      "properties": {
        "environment_id": { "type": "string", "minLength": 1 },
        "observation_kind": { "enum": ["dom_structure", "computed_style", "responsive_layout", "interaction_state", "accessibility_tree"] },
        "captured_at": { "type": "string", "format": "date-time" },
        "result": { "enum": ["observed_pass", "observed_fail"] }
      }
    },
    "observations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["observation_id", "observation_type", "result", "capture_source_id"],
        "properties": {
          "observation_id": { "type": "string", "minLength": 1 },
          "observation_type": { "enum": ["dom_structure", "computed_style", "responsive_layout", "interaction_state", "accessibility_tree"] },
          "result": { "enum": ["observed_pass", "observed_fail"] },
          "capture_source_id": { "type": "string", "pattern": "^PSL-[A-Z0-9_-]+$" }
        }
      }
    },
    "source_lineage": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/source" } },
    "limitations": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "claims": { "$ref": "#/$defs/claims" }
  },
  "$defs": {
    "sha40": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject_record_id", "coverage_subject_id", "decision_family_id", "rule_id", "obligation_id", "question_id"],
      "properties": {
        "subject_record_id": { "type": "string", "minLength": 1 },
        "coverage_subject_id": { "type": "string", "minLength": 1 },
        "decision_family_id": { "type": ["string", "null"], "minLength": 1 },
        "rule_id": { "type": ["string", "null"], "minLength": 1 },
        "obligation_id": { "type": ["string", "null"], "minLength": 1 },
        "question_id": { "type": ["string", "null"], "minLength": 1 }
      },
      "anyOf": [
        { "properties": { "obligation_id": { "type": "string" } } },
        { "properties": { "question_id": { "type": "string" } } }
      ]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "evidence_head_sha", "producer_id", "producer_repository", "producer_role", "verification_mode"],
      "properties": {
        "repository": { "const": "rezahh107/EV4-Decision-Kernel" },
        "evidence_head_sha": { "$ref": "#/$defs/sha40" },
        "producer_id": { "type": "string", "minLength": 1 },
        "producer_repository": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
        "producer_role": { "type": "string", "minLength": 1 },
        "verification_mode": { "const": "registered_immutable_capture_lineage" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "source_kind", "repository", "repository_commit", "artifact_path", "artifact_version", "content_sha256", "json_pointer"],
      "properties": {
        "source_id": { "type": "string", "pattern": "^PSL-[A-Z0-9_-]+$" },
        "source_kind": { "const": "authoritative_capture_receipt" },
        "repository": { "const": "rezahh107/EV4-Decision-Kernel" },
        "repository_commit": { "$ref": "#/$defs/sha40" },
        "artifact_path": { "type": "string", "minLength": 1 },
        "artifact_version": { "type": "string", "minLength": 1 },
        "content_sha256": { "$ref": "#/$defs/sha256" },
        "json_pointer": { "type": "string" }
      }
    },
    "claims": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_proof_verified", "readiness", "release_readiness", "production_readiness"],
      "properties": {
        "runtime_proof_verified": { "const": false },
        "readiness": { "const": false },
        "release_readiness": { "const": false },
        "production_readiness": { "const": false }
      }
    }
  }
}
