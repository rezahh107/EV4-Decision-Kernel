{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/coverage-guarantee-contract.v1.schema.json",
  "title": "EV4 Coverage Guarantee Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_id",
    "contract_version",
    "contract_class",
    "authority",
    "promotion_boundary",
    "thresholds",
    "state_machine",
    "coverage_semantics",
    "evidence_binding",
    "denominator_integrity",
    "coverage_impact_binding",
    "material_progress",
    "coverage_sensitive_paths",
    "merge_gate",
    "forbidden_claims",
    "expected_state_after_dcov_exec_001"
  ],
  "properties": {
    "contract_id": { "const": "coverage-guarantee-contract.v1" },
    "contract_version": { "const": "1.0.0" },
    "contract_class": { "const": "repository_governance_policy" },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["machine_readable_source", "human_readable_view", "manual_state_promotion_allowed"],
      "properties": {
        "machine_readable_source": { "const": "kernel/decision-governance/coverage-guarantee-contract.v1.json" },
        "human_readable_view": { "const": "docs/decision-governance/COVERAGE_GUARANTEE_CONTRACT.md" },
        "manual_state_promotion_allowed": { "const": false }
      }
    },
    "promotion_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "authority_source",
        "target_repository_content_can_approve",
        "merge_or_ci_can_approve",
        "self_authored_closure_can_approve",
        "required_predicates"
      ],
      "properties": {
        "status": { "const": "proposal_pending_external_governance_approval" },
        "authority_source": { "const": "external_project_owner_governance" },
        "target_repository_content_can_approve": { "const": false },
        "merge_or_ci_can_approve": { "const": false },
        "self_authored_closure_can_approve": { "const": false },
        "required_predicates": {
          "const": [
            "repository_evidence_capture_complete",
            "official_source_fingerprints_complete",
            "contradiction_review_complete",
            "independent_review_passed",
            "project_owner_governance_approval",
            "planning_memory_synchronized",
            "exact_head_validation_passed",
            "merged_pr_evidence_recorded",
            "post_merge_evidence_closure_accepted"
          ]
        }
      }
    },
    "thresholds": {
      "const": {
        "minimum_content_floor": 90,
        "owner_acceptance_target": 95,
        "critical_p0_and_safety_coverage": 100
      }
    },
    "state_machine": { "type": "object", "required": ["ordered_states", "eligibility"] },
    "coverage_semantics": { "type": "object", "required": ["element", "question", "critical"] },
    "evidence_binding": { "type": "object", "required": ["carrier_kind", "semantic_subject_binding_required", "proof_provenance", "coverage_credit_derivation"] },
    "denominator_integrity": { "type": "object", "required": ["known_scope_includes", "coverage_percent_requires_validated_denominator", "base_head_diff_required"] },
    "coverage_impact_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "one_new_record_per_coverage_sensitive_pr",
        "repository_pr_base_and_work_package_required",
        "exact_head_binding",
        "changed_paths_must_equal_verified_sensitive_diff",
        "historical_records_cannot_satisfy_current_pr",
        "history_ordering"
      ],
      "properties": {
        "one_new_record_per_coverage_sensitive_pr": { "const": true },
        "repository_pr_base_and_work_package_required": { "const": true },
        "exact_head_binding": { "const": "derived_from_git_and_ci_event" },
        "changed_paths_must_equal_verified_sensitive_diff": { "const": true },
        "historical_records_cannot_satisfy_current_pr": { "const": true },
        "history_ordering": {
          "const": {
            "sequence_field": "sequence_number",
            "predecessor_field": "previous_impact_id",
            "sequence_starts_at": 1,
            "gaps_allowed": false,
            "forks_allowed": false,
            "filename_order_controls_execution": false,
            "filename_sequence_disagreement_allowed": false
          }
        }
      }
    },
    "material_progress": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "measurement_active_options",
        "policy_active_rule",
        "limited_exception",
        "zero_delta_rule",
        "three_consecutive_zero_delta_fail",
        "derived_from_verified_base_head"
      ],
      "properties": {
        "measurement_active_options": { "type": "object" },
        "policy_active_rule": { "const": "complete_materially_bounded_obligations_and_close_one_real_family_slice" },
        "limited_exception": { "const": "machine_readable_reason_plus_closed_family_plus_numerator_or_completed_obligation_growth" },
        "zero_delta_rule": { "const": "blocking_defect_or_non_coverage_maintenance_with_preserved_state_and_no_credit" },
        "three_consecutive_zero_delta_fail": { "const": true },
        "derived_from_verified_base_head": { "const": true }
      }
    },
    "coverage_sensitive_paths": {
      "type": "array",
      "minItems": 8,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 },
      "allOf": [
        { "contains": { "const": ".github/workflows/validate-mvk.yml" } },
        { "contains": { "const": "package.json" } },
        { "contains": { "const": "kernel/validator/validate-coverage-guarantee" } },
        { "contains": { "const": "kernel/validator/coverage-work-package-id.mjs" } },
        { "contains": { "const": "tools/test-coverage-impact-governance.mjs" } }
      ]
    },
    "merge_gate": {
      "const": {
        "exact_head_ci_green": "required",
        "independent_pr_inspector_green": "optional_advisory",
        "explicit_owner_merge_command": "required"
      }
    },
    "forbidden_claims": { "type": "array", "minItems": 5, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "expected_state_after_dcov_exec_001": { "const": "not_measurable_pending_external_promotion" }
  }
}
