{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/coverage-impact.v1.schema.json",
  "title": "EV4 Coverage Impact Record v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["impact_id", "impact_version", "work_package_id", "work_type", "coverage_sensitive", "impact_classification", "changed_paths", "bootstrap_exception", "reason", "coverage_state_before", "coverage_state_after", "baseline_before", "baseline_after", "completed_obligation_ids", "remaining_obligation_ids", "closed_family_ids", "element_coverage_delta", "question_coverage_delta", "known_gaps", "zero_delta", "blocking_defect", "next_content_expansion_package", "exact_head_sha"],
  "properties": {
    "impact_id": { "type": "string", "pattern": "^coverage-impact\\.[a-z0-9._-]+$" },
    "impact_version": { "const": "1.0.0" },
    "work_package_id": { "type": "string", "minLength": 1 },
    "work_type": { "enum": ["foundation_bootstrap", "content_expansion", "blocking_defect", "maintenance"] },
    "coverage_sensitive": { "type": "boolean" },
    "impact_classification": { "enum": ["coverage_foundation", "coverage_increase", "blocking_defect", "not_applicable"] },
    "changed_paths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "bootstrap_exception": { "type": "boolean" },
    "reason": { "type": "string", "minLength": 1 },
    "coverage_state_before": { "enum": ["not_measurable", "policy_active", "measurement_active", "threshold_enforced", null] },
    "coverage_state_after": { "enum": ["not_measurable", "policy_active", "measurement_active", "threshold_enforced", null] },
    "baseline_before": { "type": ["string", "null"] },
    "baseline_after": { "type": ["string", "null"] },
    "completed_obligation_ids": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "remaining_obligation_ids": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "closed_family_ids": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "element_coverage_delta": { "type": ["number", "null"] },
    "question_coverage_delta": { "type": ["number", "null"] },
    "known_gaps": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "zero_delta": { "type": "boolean" },
    "blocking_defect": { "type": ["object", "null"], "required": ["defect_id", "reason"], "additionalProperties": false, "properties": { "defect_id": { "type": "string", "minLength": 1 }, "reason": { "type": "string", "minLength": 1 } } },
    "next_content_expansion_package": { "type": ["string", "null"] },
    "exact_head_sha": { "const": "derived_at_pr_runtime" }
  }
}
