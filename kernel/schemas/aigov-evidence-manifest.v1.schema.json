{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/aigov-evidence-manifest.v1.schema.json",
  "title": "EV4 AIGOV Evidence Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "manifest_id", "plan_id", "batch_id", "repository", "base_sha", "head_sha", "scope_revision", "change_class", "evidence_items", "verification_budget", "reporting_budget", "completion_receipt"],
  "properties": {
    "schema_version": {"const": "aigov-evidence-manifest.v1"},
    "manifest_id": {"type": "string", "minLength": 1},
    "plan_id": {"const": "GOV-ADOPTION-EV4-DECISION-KERNEL-5FF5D7B-V2"},
    "batch_id": {"enum": ["BATCH_A", "BATCH_B"]},
    "repository": {"const": "rezahh107/EV4-Decision-Kernel"},
    "base_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "head_sha": {"type": "string", "pattern": "^(derived_at_runtime|[0-9a-f]{40})$"},
    "scope_revision": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "change_class": {"enum": ["L0", "L1", "L2", "L3", "L4"]},
    "evidence_items": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["evidence_id", "kind", "command_or_ref", "status", "sha256"], "properties": {"evidence_id": {"type": "string", "minLength": 1}, "kind": {"enum": ["validation", "scope_disclosure", "independent_review", "owner_merge", "exact_main_receipt", "limitation"]}, "command_or_ref": {"type": "string", "minLength": 1}, "status": {"enum": ["pending", "passed", "failed", "insufficient_evidence"]}, "sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}}}},
    "verification_budget": {"type": "object", "additionalProperties": false, "required": ["required_checks", "executed_checks"], "properties": {"required_checks": {"type": "integer", "minimum": 1}, "executed_checks": {"type": "integer", "minimum": 0}}},
    "reporting_budget": {"type": "object", "additionalProperties": false, "required": ["required_sections", "reported_sections", "known_limitations"], "properties": {"required_sections": {"type": "integer", "minimum": 1}, "reported_sections": {"type": "integer", "minimum": 0}, "known_limitations": {"type": "array", "items": {"type": "string", "minLength": 1}}}},
    "completion_receipt": {"type": "object", "additionalProperties": false, "required": ["state", "default_branch", "default_branch_sha", "merge_actor", "exact_main_verified"], "properties": {"state": {"enum": ["pending_exact_main_verification", "verified", "failed"]}, "default_branch": {"const": "main"}, "default_branch_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"}, "merge_actor": {"type": ["string", "null"]}, "exact_main_verified": {"type": "boolean"}}}
  }
}
