{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/coverage-evidence-subject-registry.v1.schema.json",
  "title": "EV4 Coverage Evidence Subject Registry v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["registry_id", "version", "status", "bindings"],
  "properties": {
    "registry_id": { "const": "coverage-evidence-subject-registry.v1" },
    "version": { "const": "1.0.0" },
    "status": { "const": "semantic_binding_only_no_coverage_credit" },
    "bindings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/binding" }
    }
  },
  "$defs": {
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["binding_id", "artifact_role", "artifact_path", "symbol", "decision_family_id", "rule_id", "eligible_question_ids", "coverage_credit_granted"],
      "properties": {
        "binding_id": { "type": "string", "pattern": "^coverage-subject\\.[a-z0-9._-]+$" },
        "artifact_role": { "enum": ["deterministic_evaluator", "l2_audit"] },
        "artifact_path": { "type": "string", "minLength": 1 },
        "symbol": { "type": "string", "minLength": 1 },
        "decision_family_id": { "type": "string", "minLength": 1 },
        "rule_id": { "type": "string", "minLength": 1 },
        "eligible_question_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "coverage_credit_granted": { "const": false }
      }
    }
  }
}
