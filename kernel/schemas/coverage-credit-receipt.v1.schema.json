{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/coverage-credit-receipt.v1.schema.json",
  "title": "EV4 Coverage Credit Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["credit_id", "credit_version", "receipt_type", "subject", "baseline_id", "derivation", "source_evidence", "claims"],
  "properties": {
    "credit_id": { "type": "string", "pattern": "^coverage-credit\\.[a-z0-9._-]+$" },
    "credit_version": { "const": "1.0.0" },
    "receipt_type": { "const": "coverage_credit" },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject_record_id", "coverage_subject_id", "question_id", "decision_family_id", "rule_id"],
      "properties": {
        "subject_record_id": { "type": "string", "minLength": 1 },
        "coverage_subject_id": { "type": "string", "minLength": 1 },
        "question_id": { "type": "string", "minLength": 1 },
        "decision_family_id": { "type": "string", "minLength": 1 },
        "rule_id": { "type": "string", "minLength": 1 }
      }
    },
    "baseline_id": { "type": "string", "minLength": 1 },
    "derivation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator", "required_chain", "coverage_granted"],
      "properties": {
        "validator": { "const": "kernel/validator/validate-coverage-guarantee.mjs" },
        "required_chain": { "const": ["catalog", "matrix", "resolver_rule", "deterministic_evaluator", "valid_fixture", "invalid_fixture", "adversarial_fixture", "l2_audit", "required_runtime_or_consumer_proof", "coverage_credit"] },
        "coverage_granted": { "const": true }
      }
    },
    "source_evidence": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "claims": {
      "type": "object",
      "additionalProperties": false,
      "required": ["readiness", "release_readiness", "production_readiness"],
      "properties": {
        "readiness": { "const": false },
        "release_readiness": { "const": false },
        "production_readiness": { "const": false }
      }
    }
  }
}
