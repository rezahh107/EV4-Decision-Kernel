{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/aigov-review-receipt.v1.schema.json",
  "title": "EV4 AIGOV Externally Provenanced Review Receipt v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "plan_id",
    "batch_id",
    "target",
    "review",
    "provenance"
  ],
  "properties": {
    "schema_version": {"const": "aigov-review-receipt.v2"},
    "receipt_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "plan_id": {"const": "GOV-ADOPTION-EV4-DECISION-KERNEL-5FF5D7B-V2"},
    "batch_id": {"const": "BATCH_A"},
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "repository_id", "pr_number", "base_sha", "head_sha", "scope_revision"],
      "properties": {
        "repository": {"const": "rezahh107/EV4-Decision-Kernel"},
        "repository_id": {"const": 1292378784},
        "pr_number": {"const": 49},
        "base_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "head_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "scope_revision": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["technical_status", "reviewed_at", "reviewer_identity", "implementer_identity", "review_package_sha256", "review_package_file_sha256", "decision_projection_sha256", "artifact_manifest_sha256", "ci_identity_digest", "sequence_producer_identity_digest", "findings"],
      "properties": {
        "technical_status": {"const": "GREEN_TECHNICALLY_READY"},
        "reviewed_at": {"type": "string", "format": "date-time"},
        "reviewer_identity": {"type": "string", "minLength": 1},
        "implementer_identity": {"type": "string", "minLength": 1},
        "review_package_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "review_package_file_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "decision_projection_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "artifact_manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "ci_identity_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "sequence_producer_identity_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["severity", "summary", "blocking"],
            "properties": {
              "severity": {"enum": ["critical", "high", "medium", "low", "info"]},
              "summary": {"type": "string", "minLength": 1},
              "blocking": {"type": "boolean"}
            }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_source",
        "inspector_repository",
        "inspector_repository_id",
        "inspector_commit_sha",
        "inspector_commit_api_url",
        "inspector_commit_html_url",
        "protocol_version",
        "receipt_path",
        "trust_policy_path",
        "trust_policy_sha256",
        "observed_at",
        "immutable_artifacts"
      ],
      "properties": {
        "evidence_source": {"const": "github_rest_api_https"},
        "inspector_repository": {"const": "rezahh107/PR-Inspector"},
        "inspector_repository_id": {"const": 1288323264},
        "inspector_commit_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "inspector_commit_api_url": {"type": "string", "pattern": "^https://api\\.github\\.com/repos/rezahh107/PR-Inspector/commits/[0-9a-f]{40}$"},
        "inspector_commit_html_url": {"type": "string", "pattern": "^https://github\\.com/rezahh107/PR-Inspector/commit/[0-9a-f]{40}$"},
        "protocol_version": {"const": "v1.10.1"},
        "receipt_path": {"type": "string", "pattern": "^reviews/EV4-Decision-Kernel/pr-49/[0-9a-f]{40}/[0-9a-f]{64}/aigov-review-receipt\\.json$"},
        "trust_policy_path": {"const": "protocols/v1.10.1/trust/INSPECTOR_TRUST_POLICY.json"},
        "trust_policy_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "observed_at": {"type": "string", "format": "date-time"},
        "immutable_artifacts": {
          "type": "array",
          "minItems": 6,
          "maxItems": 7,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "path", "sha256", "git_blob_sha"],
            "properties": {
              "name": {"enum": ["review-package.json", "DECISION_PROJECTION.json", "OWNER_DECISION_CARD.fa.md", "TECHNICAL_HANDOFF.en.md", "OWNER_RESULT.fa.txt", "NEXT_ACTION_PROMPT.en.md", "artifact-manifest.json"]},
              "path": {"type": "string", "minLength": 1},
              "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "git_blob_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
            }
          }
        }
      }
    }
  }
}
