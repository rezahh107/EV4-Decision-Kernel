{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/element-reconciliation-ledger.v1.schema.json",
  "title": "EV4 Element Reconciliation Ledger v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["ledger_id", "version", "status", "source_base_commit", "known_scope_count", "confirmed_denominator_count", "denominator_state", "records"],
  "properties": {
    "ledger_id": { "const": "element-reconciliation-ledger.v1" },
    "version": { "type": "string", "pattern": "^1\\.[0-9]+\\.[0-9]+$" },
    "status": { "enum": ["active_seed", "active"] },
    "source_base_commit": { "$ref": "#/$defs/sha40" },
    "known_scope_count": { "type": "integer", "minimum": 1 },
    "confirmed_denominator_count": { "type": "integer", "minimum": 0 },
    "denominator_state": { "enum": ["unresolved", "validated"] },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/record" }
    }
  },
  "$defs": {
    "sha40": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "path", "artifact_version", "retrieval_identity", "content_hash", "repository_commit", "repository_blob_sha", "provenance_classification", "verification_mode"],
      "properties": {
        "source_type": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "artifact_version": { "type": "string", "minLength": 1 },
        "retrieval_identity": { "type": "string", "minLength": 1 },
        "content_hash": { "$ref": "#/$defs/sha256" },
        "repository_commit": { "$ref": "#/$defs/sha40" },
        "repository_blob_sha": { "$ref": "#/$defs/sha40" },
        "json_pointer": { "type": ["string", "null"] },
        "provenance_classification": {
          "enum": ["existing_repository_contract", "verified_current_repository_fact", "verified_current_official_fact", "recovered_historical_requirement", "recovered_from_multiple_sources", "derived_architectural_requirement", "unresolved_candidate"]
        },
        "verification_mode": { "enum": ["local_file", "git_blob_at_commit"] }
      }
    },
    "evidenceCarrier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "subject_record_id", "coverage_subject_id", "artifact_role", "artifact_path", "artifact_version", "content_sha256", "head_binding", "repository_commit", "json_pointer", "symbol"],
      "properties": {
        "evidence_id": { "type": "string", "pattern": "^EVC-[A-Z0-9_-]+$" },
        "subject_record_id": { "type": "string", "minLength": 1 },
        "coverage_subject_id": { "type": "string", "minLength": 1 },
        "artifact_role": { "$ref": "#/$defs/artifactRole" },
        "artifact_path": { "type": "string", "minLength": 1 },
        "artifact_version": { "type": "string", "minLength": 1 },
        "content_sha256": { "$ref": "#/$defs/sha256" },
        "head_binding": { "enum": ["git_runtime_head", "pinned_commit"] },
        "repository_commit": { "anyOf": [{ "$ref": "#/$defs/sha40" }, { "type": "null" }] },
        "json_pointer": { "type": ["string", "null"] },
        "symbol": { "type": ["string", "null"], "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "head_binding": { "const": "pinned_commit" } }, "required": ["head_binding"] },
          "then": { "properties": { "repository_commit": { "$ref": "#/$defs/sha40" } } },
          "else": { "properties": { "repository_commit": { "type": "null" } } }
        }
      ]
    },
    "artifactRole": {
      "enum": ["catalog_record", "matrix", "resolver_rule", "deterministic_evaluator", "valid_fixture", "invalid_fixture", "adversarial_fixture", "l2_audit", "runtime_proof", "consumer_proof", "coverage_credit", "decision_question", "p0_family", "safety_gate", "runtime_check", "not_applicable_evidence", "denominator_change"]
    },
    "evidenceRef": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        { "$ref": "#/$defs/evidenceCarrier" }
      ]
    },
    "obligation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["obligation_id", "status", "critical", "evidence_refs", "not_applicable_reason"],
      "properties": {
        "obligation_id": { "type": "string", "minLength": 1 },
        "status": { "enum": ["end_to_end_covered", "partial", "candidate", "unresolved", "pending_official_confirmation", "not_applicable_with_validated_reason", "superseded"] },
        "critical": { "type": "boolean" },
        "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/evidenceRef" }, "uniqueItems": true },
        "not_applicable_reason": { "type": ["object", "null"], "required": ["reason_code", "evidence_refs", "validator_accepted"], "properties": { "reason_code": { "type": "string", "minLength": 1 }, "evidence_refs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/evidenceRef" } }, "validator_accepted": { "const": true } }, "additionalProperties": false }
      }
    },
    "obligations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["applicable_decision_questions", "applicable_p0_families", "required_safety_gates", "required_runtime_checks", "required_consumer_proofs"],
      "properties": {
        "applicable_decision_questions": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/obligation" } },
        "applicable_p0_families": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/obligation" } },
        "required_safety_gates": { "type": "array", "items": { "$ref": "#/$defs/obligation" } },
        "required_runtime_checks": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/obligation" } },
        "required_consumer_proofs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/obligation" } }
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_id", "record_type", "element_id", "display_name", "evidence_state", "denominator_membership", "source_references", "element_obligations", "resolution_state", "known_limitations", "duplicate_of", "superseded_by"],
      "properties": {
        "record_id": { "type": "string", "pattern": "^EL-[A-Z0-9_-]+$" },
        "record_type": { "enum": ["atomic", "compound", "child_atom", "layout_mode", "classic_widget", "capability", "unresolved_candidate"] },
        "element_id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string", "minLength": 1 },
        "evidence_state": { "enum": ["confirmed", "candidate", "unresolved", "pending_official_confirmation", "not_applicable_with_validated_reason", "superseded"] },
        "denominator_membership": { "enum": ["confirmed", "candidate", "unresolved", "excluded_duplicate", "excluded_superseded", "not_applicable_with_validated_reason"] },
        "source_references": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/sourceRef" } },
        "element_obligations": { "$ref": "#/$defs/obligations" },
        "resolution_state": { "enum": ["covered", "partial", "unresolved", "pending_official_confirmation", "not_applicable_with_validated_reason", "superseded"] },
        "known_limitations": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "duplicate_of": { "type": ["string", "null"] },
        "superseded_by": { "type": ["string", "null"] }
      }
    }
  }
}
