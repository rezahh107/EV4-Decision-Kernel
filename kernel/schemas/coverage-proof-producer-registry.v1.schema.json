{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/coverage-proof-producer-registry.v1.schema.json",
  "title": "EV4 Coverage Proof Producer Registry v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["registry_id", "version", "status", "repository", "producers"],
  "properties": {
    "registry_id": { "const": "coverage-proof-producer-registry.v1" },
    "version": { "const": "1.0.0" },
    "status": { "const": "active_fail_closed" },
    "repository": { "const": "rezahh107/EV4-Decision-Kernel" },
    "producers": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/producer" }
    }
  },
  "$defs": {
    "sha40": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producer_id", "producer_repository", "producer_role", "receipt_types", "allowed_environment_ids", "allowed_consumer_ids", "registration_source", "active"],
      "properties": {
        "producer_id": { "type": "string", "pattern": "^[a-z0-9._-]+$" },
        "producer_repository": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
        "producer_role": { "enum": ["Responsive", "Project Gate", "Architect", "CE", "Builder", "external_observer"] },
        "receipt_types": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["runtime_proof", "consumer_proof"] } },
        "allowed_environment_ids": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "allowed_consumer_ids": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "registration_source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository", "repository_commit", "artifact_path", "content_sha256", "json_pointer"],
          "properties": {
            "repository": { "const": "rezahh107/EV4-Decision-Kernel" },
            "repository_commit": { "$ref": "#/$defs/sha40" },
            "artifact_path": { "type": "string", "minLength": 1 },
            "content_sha256": { "$ref": "#/$defs/sha256" },
            "json_pointer": { "type": "string" }
          }
        },
        "active": { "const": true }
      }
    }
  }
}
