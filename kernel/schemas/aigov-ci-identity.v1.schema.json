{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/aigov-ci-identity.v1.schema.json",
  "title": "EV4 Authoritative Exact-Head GitHub Actions Identity v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "identity_digest", "repository", "repository_id", "pr_number", "tested_sha", "tested_ref_type", "synthetic_merge", "workflow", "run", "jobs", "check_producer", "artifacts", "completed_at", "evidence_source", "observed_at"],
  "properties": {
    "schema_version": {"const": "aigov-ci-identity.v1"},
    "identity_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "repository": {"const": "rezahh107/EV4-Decision-Kernel"},
    "repository_id": {"const": 1292378784},
    "pr_number": {"const": 49},
    "tested_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "tested_ref_type": {"const": "pull_request_head"},
    "synthetic_merge": {"const": false},
    "workflow": {
      "type": "object", "additionalProperties": false, "required": ["workflow_id", "name", "path"],
      "properties": {"workflow_id": {"type": "integer", "minimum": 1}, "name": {"const": "Validate MVK"}, "path": {"const": ".github/workflows/validate-mvk.yml"}}
    },
    "run": {
      "type": "object", "additionalProperties": false, "required": ["run_id", "run_attempt", "event", "head_branch", "html_url", "api_url", "conclusion", "created_at", "updated_at"],
      "properties": {
        "run_id": {"type": "integer", "minimum": 1}, "run_attempt": {"type": "integer", "minimum": 1}, "event": {"const": "pull_request"},
        "head_branch": {"type": "string", "minLength": 1}, "html_url": {"type": "string", "format": "uri"}, "api_url": {"type": "string", "format": "uri"},
        "conclusion": {"const": "success"}, "created_at": {"type": "string", "format": "date-time"}, "updated_at": {"type": "string", "format": "date-time"}
      }
    },
    "jobs": {
      "type": "array", "minItems": 3, "uniqueItems": true,
      "items": {"type": "object", "additionalProperties": false, "required": ["job_id", "name", "check_run_url", "html_url", "started_at", "completed_at", "conclusion", "check_external_id"], "properties": {
        "job_id": {"type": "integer", "minimum": 1}, "name": {"type": "string", "minLength": 1}, "check_run_url": {"type": "string", "format": "uri"}, "html_url": {"type": "string", "format": "uri"},
        "started_at": {"type": "string", "format": "date-time"}, "completed_at": {"type": "string", "format": "date-time"}, "conclusion": {"const": "success"}, "check_external_id": {"type": ["string", "null"]}
      }}
    },
    "check_producer": {"type": "object", "additionalProperties": false, "required": ["app_id", "slug", "name", "owner"], "properties": {"app_id": {"const": 15368}, "slug": {"const": "github-actions"}, "name": {"const": "GitHub Actions"}, "owner": {"const": "github"}}},
    "artifacts": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["artifact_id", "name", "api_url", "archive_download_url", "digest", "created_at", "expires_at"], "properties": {
      "artifact_id": {"type": "integer", "minimum": 1}, "name": {"type": "string", "minLength": 1}, "api_url": {"type": "string", "format": "uri"}, "archive_download_url": {"type": "string", "format": "uri"}, "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}, "created_at": {"type": "string", "format": "date-time"}, "expires_at": {"type": "string", "format": "date-time"}
    }}},
    "completed_at": {"type": "string", "format": "date-time"},
    "evidence_source": {"const": "github_rest_api_https"},
    "observed_at": {"type": "string", "format": "date-time"}
  }
}
