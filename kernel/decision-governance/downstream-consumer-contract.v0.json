  "pin_snapshot_policy": {
    "commit_must_exist": true,
    "commit_must_be_ancestor_of_validation_head": true,
    "contract_must_exist_at_pinned_commit": true,
    "all_referenced_artifacts_read_from_pinned_commit": true,
    "current_execution_files_must_match_pinned_snapshot": true,
    "acceptance_semantics_only": true,
    "orchestration_files_excluded": [
      "package.json",
      "package-lock.json"
