    "post_merge_verification": "required_per_batch"
  },
  "capability_lifecycle": {
    "states": [
      "registered_planned_task",
      "authorized_next_task",
      "active_implementation",
      "pending_exact_head_validation",
      "pending_independent_review",
      "pending_owner_merge",
      "pending_exact_main_verification",
      "completed",
      "blocked"
    ],
    "current_state": "active_implementation",
    "completion_requires_default_branch_receipt": true,
    "registration_is_not_activation": true,
    "merge_is_not_completion": true
  },
  "change_classes": [
    {"id": "L0", "meaning": "read_only_or_no_repository_change", "minimum_verification_budget": 1, "minimum_reporting_budget": 1},
    {"id": "L1", "meaning": "bounded_documentation_or_metadata", "minimum_verification_budget": 2, "minimum_reporting_budget": 1},
    {"id": "L2", "meaning": "bounded_contract_or_validator_compatible_change", "minimum_verification_budget": 4, "minimum_reporting_budget": 2},
    {"id": "L3", "meaning": "governance_authority_or_ci_enforcement_change", "minimum_verification_budget": 10, "minimum_reporting_budget": 4},
    {"id": "L4", "meaning": "multi_repository_security_or_irreversible_change", "minimum_verification_budget": 14, "minimum_reporting_budget": 6}
  ],
  "security_profile": {
    "profile_id": "standard_minimum_public_repository",
    "fail_closed_on_missing_evidence": true,
    "treat_repository_inputs_as_untrusted": true,
    "immutable_action_pins_required": true,
    "workflow_permissions_must_not_expand": true,
    "secrets_must_not_change": true,
    "forbidden_changes": [
      "secret_change",
      "permission_change",
      "ruleset_change",
      "branch_protection_change",
      "force_push",
      "history_rewrite",
      "external_repository_write",
      "broad_dependency_upgrade",
      "destructive_deletion",
      "auto_merge"
    ],
    "enforcement_carriers": [
      {"forbidden_change": "secret_change", "classification": "implemented_detector", "carrier": "workflow_secret_expression_detector"},
      {"forbidden_change": "permission_change", "classification": "implemented_detector", "carrier": "workflow_permission_semantic_diff"},
      {"forbidden_change": "ruleset_change", "classification": "implemented_detector_and_external_evidence", "carrier": "repository_settings_mutation_detector"},
      {"forbidden_change": "branch_protection_change", "classification": "implemented_detector_and_external_evidence", "carrier": "repository_settings_mutation_detector"},
      {"forbidden_change": "force_push", "classification": "implemented_detector", "carrier": "force_push_command_detector"},
      {"forbidden_change": "history_rewrite", "classification": "implemented_detector", "carrier": "history_rewrite_command_detector"},
      {"forbidden_change": "external_repository_write", "classification": "implemented_detector", "carrier": "external_repository_write_detector"},
      {"forbidden_change": "broad_dependency_upgrade", "classification": "implemented_detector", "carrier": "canonical_dependency_diff_detector"},
      {"forbidden_change": "destructive_deletion", "classification": "implemented_detector", "carrier": "destructive_deletion_detector"},
      {"forbidden_change": "auto_merge", "classification": "implemented_detector", "carrier": "merge_and_auto_merge_command_detector"}
    ],
    "repository_settings_enforcement": "external_evidence_required_not_proven"
  },
  "scope_contract": {
    "required_sets": ["committed", "excluded", "deferred_not_deleted", "dependencies", "completion_evidence"],
    "scope_revision_algorithm": "sha256-jcs-without-scope_revision",
    "head_binding": "exact_runtime_head",
    "silent_material_deletion": "forbidden"
  },
  "evidence_contract": {
    "manifest_required": true,
    "stable_inputs_and_outputs_required": true,
    "exact_head_required": true,
    "completion_receipt_default_branch_required": true,
    "target_authored_claim_is_not_external_authority": true
  },
  "reporting_contract": {
    "material_failures_must_be_reported": true,
    "known_limitations_must_be_reported": true,
    "prompt_or_coaching_text_is_not_completion_evidence": true
  },
  "sequence": {
    "ordered_events": [
      "start_preflight",
      "scope_committed",
      "scope_disclosed",
      "implementation_complete",
      "exact_head_validated",
      "independent_review_green",
      "owner_merge",
      "exact_main_verified"
    ],
    "review_invalidated_by_head_change": true,
    "review_invalidated_by_scope_revision_change": true,
    "owner_merge_cannot_be_skipped": true
  },
  "rules": [
